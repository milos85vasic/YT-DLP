#!/bin/bash
#
# Start YT-DLP services with automatic container runtime detection
# Supports both Podman and Docker (prefers Podman)
#

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

get_compose_cmd() {
    local runtime="$1"
    if [ "$runtime" = "podman" ]; then
        if command -v podman-compose &> /dev/null; then
            echo "podman-compose"
        else
            echo "podman compose"
        fi
    else
        if command -v docker-compose &> /dev/null; then
            echo "docker-compose"
        else
            echo "docker compose"
        fi
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    echo "Please install Podman or Docker."
    exit 1
fi

COMPOSE_CMD=$(get_compose_cmd "$CONTAINER_RUNTIME")

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Clean up stale cookies that can break non-YouTube downloads
# Only remove if cookies don't contain YouTube domains (legacy bad cookies)
# =============================================================================

# =============================================================================
# Sync fresh cookies from yt-dlp to metube (yt-dlp/cookies.txt is user-managed
# and usually fresher than the metube upload)
# =============================================================================

if [ -f "$SCRIPT_DIR/yt-dlp/cookies/cookies.txt" ] && grep -qE "youtube\.com|youtu\.be" "$SCRIPT_DIR/yt-dlp/cookies/cookies.txt" 2>/dev/null; then
    echo -e "${GREEN}✓ Fresh YouTube cookies found in yt-dlp/cookies/cookies.txt — syncing to metube${NC}"
    cp -f "$SCRIPT_DIR/yt-dlp/cookies/cookies.txt" "$SCRIPT_DIR/metube/config/cookies.txt"
    chmod 644 "$SCRIPT_DIR/metube/config/cookies.txt"
elif [ -f "$SCRIPT_DIR/metube/config/cookies.txt" ]; then
    if [ "${YOUTUBE_COOKIES:-}" = "false" ]; then
        echo -e "${YELLOW}⚠ YOUTUBE_COOKIES=false — removing metube/config/cookies.txt${NC}"
        rm -f "$SCRIPT_DIR/metube/config/cookies.txt"
    elif grep -qE "youtube\.com|youtu\.be" "$SCRIPT_DIR/metube/config/cookies.txt" 2>/dev/null; then
        echo -e "${GREEN}✓ YouTube cookies found in metube/config/cookies.txt — keeping${NC}"
    else
        echo -e "${YELLOW}⚠ Removing stale cookies file (no YouTube domains found)${NC}"
        rm -f "$SCRIPT_DIR/metube/config/cookies.txt"
    fi
fi

# =============================================================================
# Initialize Environment
# =============================================================================

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Initializing Environment${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/init"

# =============================================================================
# Update Images
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Updating Container Images${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/update-images"

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Starting Services${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

# =============================================================================
# Start Services
# =============================================================================

if [ "$USE_VPN" = "true" ]; then
    echo -e "${CYAN}Starting services WITH VPN...${NC}"
    echo -e "Runtime: ${CONTAINER_RUNTIME}"
    echo ""
    if [ "$CONTAINER_RUNTIME" = "docker" ]; then
        $COMPOSE_CMD --profile vpn --profile docker up -d
    else
        $COMPOSE_CMD --profile vpn up -d
    fi
else
    echo -e "${CYAN}Starting services WITHOUT VPN...${NC}"
    echo -e "Runtime: ${CONTAINER_RUNTIME}"
    echo ""
    if [ "$CONTAINER_RUNTIME" = "docker" ]; then
        $COMPOSE_CMD --profile no-vpn --profile docker up -d
    else
        $COMPOSE_CMD --profile no-vpn up -d
    fi
fi

# =============================================================================
# Post-startup: update yt-dlp inside metube containers and sync cookies
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}    Post-startup Updates${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

# Update yt-dlp inside metube containers to nightly (YouTube changes frequently)
for container in metube metube-direct; do
    if $CONTAINER_RUNTIME ps --format "{{.Names}}" | grep -q "^${container}$"; then
        echo -e "${BLUE}Updating yt-dlp in $container...${NC}"
        $CONTAINER_RUNTIME exec "$container" pip install --quiet --upgrade \
            "yt-dlp@https://github.com/yt-dlp/yt-dlp-nightly-builds/releases/latest/download/yt-dlp.tar.gz" 2>/dev/null || true
        $CONTAINER_RUNTIME exec "$container" python3 -c "import yt_dlp; print('yt-dlp version:', yt_dlp.version.__version__)" 2>/dev/null || true
    fi
done

# Sync fresh cookies from yt-dlp to metube if available
if [ -f "$SCRIPT_DIR/yt-dlp/cookies/cookies.txt" ]; then
    for container in metube metube-direct; do
        if $CONTAINER_RUNTIME ps --format "{{.Names}}" | grep -q "^${container}$"; then
            echo -e "${BLUE}Syncing cookies to $container...${NC}"
            $CONTAINER_RUNTIME cp "$SCRIPT_DIR/yt-dlp/cookies/cookies.txt" "$container:/config/cookies.txt" 2>/dev/null || true
        fi
    done
fi

echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}    Services started successfully!${NC}"
echo -e "${GREEN}============================================${NC}"
echo ""

echo -e "${CYAN}Container Runtime:${NC} $CONTAINER_RUNTIME"
echo -e "${CYAN}Compose Command:${NC} $COMPOSE_CMD"
echo ""

if [ "$USE_VPN" = "true" ]; then
    echo -e "${BLUE}Access URLs (With VPN):${NC}"
    echo ""
    echo "  Landing Page (VPN): http://localhost:8087"
    echo "  MeTube (VPN):       http://localhost:8086"
    echo "  VPN Proxy:          http://localhost:3130"
    echo ""
    echo "Check VPN connection:"
    echo "  $CONTAINER_RUNTIME exec openvpn-yt-dlp wget -qO- ifconfig.me"
    echo ""
else
    echo -e "${BLUE}Access URLs (No VPN):${NC}"
    echo ""
    echo "  Landing Page:     http://localhost:8086"
    echo "  MeTube Direct:    http://localhost:8088"
    echo "  MeTube API:       http://localhost:8088/api/json/v1/"
    echo "  YT-DLP Dashboard: http://localhost:9090"
    echo ""
fi

echo -e "${BLUE}Quick Commands:${NC}"
echo ""
echo "Download single video:"
echo "  $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp 'https://www.youtube.com/watch?v=VIDEO_ID'"
echo ""
echo "Download from batch file:"
echo "  $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp --batch-file /config/urls.txt"
echo ""
echo "Check container logs:"
echo "  $COMPOSE_CMD logs -f"
