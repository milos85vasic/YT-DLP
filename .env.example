# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED SETTINGS
# ============================================

# Container runtime preference (auto-detected if not set)
# Options: podman, docker, auto
CONTAINER_RUNTIME=auto

# Enable/disable VPN (true/false)
USE_VPN=false

# Download directory path (absolute path recommended)
DOWNLOAD_DIR=/mnt/downloads

# User/Group IDs for file ownership inside containers
# Auto-detected from current user if not set
PUID=1000
PGID=1000

# ============================================
# VPN SETTINGS (required if USE_VPN=true)
# ============================================

# VPN Provider credentials
VPN_USERNAME=your_vpn_username
VPN_PASSWORD=your_vpn_password

# Path to OpenVPN configuration file (.ovpn)
VPN_OVPN_PATH=/path/to/your/config.ovpn

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Timezone
TZ=Europe/Moscow

# Metube Landing Page port (no VPN) - Cookie authentication gateway
METUBE_PORT=8086

# Landing Page port (VPN) - Cookie authentication gateway
LANDING_PAGE_VPN_PORT=8087

# Metube Web UI port (no VPN) - Direct MeTube access
METUBE_DIRECT_PORT=8088

# yt-dlp VPN proxy port
YTDLP_VPN_PORT=3130

# Service mode for automatic processing (true/false)
SERVICE_MODE=false

# YouTube cookies file for accessing restricted content
# Place cookies.txt in ./yt-dlp/cookies/
YOUTUBE_COOKIES=false

# Quality settings
DEFAULT_QUALITY=1080p
