#!/bin/bash
#
# Download helper script for YT-DLP
# Supports both Podman and Docker
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    exit 1
fi

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Show Help
# =============================================================================

show_help() {
    echo -e "${BLUE}YT-DLP Download Helper${NC}"
    echo ""
    echo "Usage:"
    echo "  ./download <URL>              Download a single video"
    echo "  ./download --batch           Download from ./yt-dlp/config/urls.txt"
    echo "  ./download --channels        Download from subscribed channels"
    echo "  ./download --help            Show this help message"
    echo ""
    echo "Examples:"
    echo "  ./download 'https://www.youtube.com/watch?v=dQw4w9WgXcQ'"
    echo "  ./download 'https://vkvideo.ru/video/playlist/-220068665_92'"
    echo "  ./download --batch"
    echo "  ./download --channels"
    echo ""
    echo -e "${CYAN}Container Runtime:${NC} $CONTAINER_RUNTIME"
    echo ""
    echo "For advanced usage, run yt-dlp directly:"
    echo "  $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp [OPTIONS] <URL>"
}

# =============================================================================
# Main Logic
# =============================================================================

if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

# Determine which container to use
CONTAINER_NAME="yt-dlp-cli"

# Handle help first (before checking container)
case "$1" in
    --help|-h)
        show_help
        exit 0
        ;;
esac

# Check if container is running (skip for help)
if ! $CONTAINER_RUNTIME ps --format "table {{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
    echo -e "${YELLOW}WARNING: Container '$CONTAINER_NAME' is not running.${NC}"
    echo "Please start the services first with: ./start"
    exit 1
fi

# =============================================================================
# Cookie validation helper
# =============================================================================

warn_stale_cookies() {
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}⚠  WARNING: Your YouTube cookies may be stale or expired.${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "YouTube periodically rotates cookies as a security measure."
    echo "If downloads fail with 'Sign in to confirm you're not a bot',"
    echo "your cookies need to be refreshed."
    echo ""
    echo "To fix:"
    echo "  1. Go to the Landing Page: http://localhost:8086"
    echo "  2. Sign in to YouTube in your browser"
    echo "  3. Export fresh cookies (Get cookies.txt extension)"
    echo "  4. Upload via the Landing Page"
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# =============================================================================
# Build base YT-DLP arguments (config + optional cookies)
# =============================================================================

BASE_ARGS=("--config-location" "/config/yt-dlp.conf")

# Prefer metube cookies (user-uploaded via landing page, usually fresher)
# Fall back to yt-dlp CLI cookies
COOKIE_SOURCE=""
if [ -s ./metube/config/cookies.txt ] && grep -qE "youtube\.com|youtu\.be" ./metube/config/cookies.txt 2>/dev/null; then
    BASE_ARGS+=("--cookies" "/tmp/metube-cookies.txt")
    COOKIE_SOURCE="metube"
    # Warn if cookies are older than 1 hour (very likely stale for YouTube)
    if [ "$(find ./metube/config/cookies.txt -mmin +60 2>/dev/null)" ]; then
        warn_stale_cookies
    fi
elif [ -s ./yt-dlp/cookies/cookies.txt ]; then
    BASE_ARGS+=("--cookies" "/cookies/cookies.txt")
    COOKIE_SOURCE="yt-dlp"
    if [ "$(find ./yt-dlp/cookies/cookies.txt -mmin +60 2>/dev/null)" ]; then
        warn_stale_cookies
    fi
fi

# =============================================================================
# Handle download operations
# =============================================================================

case "$1" in
    --batch)
        echo -e "${BLUE}Downloading from urls.txt...${NC}"
        if [ -f ./yt-dlp/config/urls.txt ]; then
            $CONTAINER_RUNTIME exec --user root $CONTAINER_NAME \
                yt-dlp "${BASE_ARGS[@]}" --batch-file /config/urls.txt
        else
            echo -e "${YELLOW}urls.txt not found. Creating template...${NC}"
            cat > ./yt-dlp/config/urls.txt << 'EOF'
# Add video URLs here, one per line
# Example:
# https://www.youtube.com/watch?v=VIDEO_ID
# https://www.youtube.com/playlist?list=PLAYLIST_ID
# https://vkvideo.ru/video/playlist/-220068665_92
EOF
            echo -e "${GREEN}✓${NC} Created urls.txt at ./yt-dlp/config/urls.txt"
            echo "Please add URLs to the file and run again."
        fi
        ;;
    --channels)
        echo -e "${BLUE}Downloading from subscribed channels...${NC}"
        if [ -f ./yt-dlp/config/channels.txt ]; then
            $CONTAINER_RUNTIME exec --user root $CONTAINER_NAME \
                yt-dlp "${BASE_ARGS[@]}" --batch-file /config/channels.txt --dateafter now-7days
        else
            echo -e "${YELLOW}channels.txt not found. Creating template...${NC}"
            cat > ./yt-dlp/config/channels.txt << 'EOF'
# Add channel URLs here, one per line
# Example:
# https://www.youtube.com/c/ChannelName
# https://www.youtube.com/@ChannelHandle
# https://www.youtube.com/channel/CHANNEL_ID
EOF
            echo -e "${GREEN}✓${NC} Created channels.txt at ./yt-dlp/config/channels.txt"
            echo "Please add channel URLs to the file and run again."
        fi
        ;;
    *)
        URL="$1"
        echo -e "${BLUE}Downloading:${NC} $URL"
        shift

        # Build per-URL args
        URL_ARGS=("${BASE_ARGS[@]}")

        # Only add YouTube-specific extractor args for YouTube URLs
        # Use android client first — web client often triggers bot detection
        if echo "$URL" | grep -qiE '(youtube\.com|youtu\.be|youtube-nocookie\.com)'; then
            URL_ARGS+=("--extractor-args" "youtube:player_client=android,mweb,web")
        fi

        $CONTAINER_RUNTIME exec --user root $CONTAINER_NAME \
            yt-dlp "${URL_ARGS[@]}" "$@" "$URL"
        ;;
esac
