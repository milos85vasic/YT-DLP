#!/bin/bash
#
# YT-DLP Docker/Podman Setup Script
# Initializes the environment, creates directories, and validates configuration
#

set -e

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Header
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}    YT-DLP Environment Setup Script${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

get_compose_cmd() {
    local runtime="$1"
    if [ "$runtime" = "podman" ]; then
        if command -v podman-compose &> /dev/null; then
            echo "podman-compose"
        else
            echo "podman compose"
        fi
    else
        if command -v docker-compose &> /dev/null; then
            echo "docker-compose"
        else
            echo "docker compose"
        fi
    fi
}

# Detect runtime
CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    echo -e "${YELLOW}Please install either Podman or Docker:${NC}"
    echo "  • Podman: https://podman.io/getting-started/installation"
    echo "  • Docker: https://docs.docker.com/get-docker/"
    exit 1
fi

COMPOSE_CMD=$(get_compose_cmd "$CONTAINER_RUNTIME")

echo -e "${CYAN}Container Runtime:${NC} $CONTAINER_RUNTIME"
echo -e "${CYAN}Compose Command:${NC} $COMPOSE_CMD"
echo ""

# =============================================================================
# Environment File Validation
# =============================================================================

if [ ! -f .env ]; then
    echo -e "${YELLOW}WARNING: .env file not found in current directory.${NC}"
    echo ""
    echo -e "${BLUE}Creating .env from template...${NC}"
    
    if [ -f .env.example ]; then
        cp .env.example .env
        echo -e "${GREEN}✓ Created .env from .env.example${NC}"
        echo ""
        echo -e "${YELLOW}Please edit .env and configure your settings before continuing.${NC}"
        echo "Required settings:"
        echo "  • USE_VPN (true/false)"
        echo "  • DOWNLOAD_DIR (absolute path)"
        echo "  • VPN credentials (if USE_VPN=true)"
        exit 1
    else
        echo -e "${RED}ERROR: .env.example template not found!${NC}"
        exit 1
    fi
fi

echo -e "${BLUE}Loading variables from .env file...${NC}"

set -a
source .env
set +a

# =============================================================================
# User/Group ID Detection (file ownership inside containers)
# =============================================================================

CURRENT_PUID=$(id -u)
CURRENT_PGID=$(id -g)

if [ -z "${PUID:-}" ] || [ "$PUID" != "$CURRENT_PUID" ]; then
    PUID="$CURRENT_PUID"
    # Update .env file
    if grep -q "^PUID=" .env 2>/dev/null; then
        sed -i "s/^PUID=.*/PUID=$PUID/" .env
    else
        echo "PUID=$PUID" >> .env
    fi
fi

if [ -z "${PGID:-}" ] || [ "$PGID" != "$CURRENT_PGID" ]; then
    PGID="$CURRENT_PGID"
    if grep -q "^PGID=" .env 2>/dev/null; then
        sed -i "s/^PGID=.*/PGID=$PGID/" .env
    else
        echo "PGID=$PGID" >> .env
    fi
fi

echo -e "${GREEN}✓${NC} File ownership: UID=$PUID, GID=$PGID ($(id -un))"
echo ""

# =============================================================================
# Variable Validation
# =============================================================================

REQUIRED_VARS=(
    "USE_VPN:Enable/Disable VPN (true/false)"
    "DOWNLOAD_DIR:Download Directory"
)

VPN_VARS=(
    "VPN_USERNAME:VPN Username"
    "VPN_PASSWORD:VPN Password"
    "VPN_OVPN_PATH:VPN OpenVPN config file path"
)

VALIDATION_FAILED=false

echo -e "${BLUE}Validating required variables...${NC}"
echo ""

for var_info in "${REQUIRED_VARS[@]}"; do
    var_name="${var_info%%:*}"
    var_description="${var_info##*:}"
    var_value="${!var_name}"
    
    if [ -z "$var_value" ]; then
        echo -e "${RED}✗ ERROR: $var_name ($var_description) is not set.${NC}"
        VALIDATION_FAILED=true
    else
        if [[ "$var_name" == *"PASSWORD"* ]] || [[ "$var_name" == *"USERNAME"* ]]; then
            display_value="***masked***"
        else
            display_value="$var_value"
        fi
        echo -e "${GREEN}✓${NC} $var_name: $display_value"
    fi
done

# VPN-specific validation
if [ "$USE_VPN" = "true" ]; then
    echo ""
    echo -e "${BLUE}VPN enabled - checking VPN-specific variables...${NC}"
    
    for var_info in "${VPN_VARS[@]}"; do
        var_name="${var_info%%:*}"
        var_description="${var_info##*:}"
        var_value="${!var_name}"
        
        if [ -z "$var_value" ]; then
            echo -e "${RED}✗ ERROR: $var_name ($var_description) is not set.${NC}"
            VALIDATION_FAILED=true
        else
            if [[ "$var_name" == *"PASSWORD"* ]] || [[ "$var_name" == *"USERNAME"* ]]; then
                display_value="***masked***"
            else
                display_value="$var_value"
            fi
            echo -e "${GREEN}✓${NC} $var_name: $display_value"
        fi
    done
    
    # Check VPN config file
    echo ""
    echo -e "${BLUE}Checking VPN configuration file...${NC}"
    
    if [ ! -f "$VPN_OVPN_PATH" ]; then
        echo -e "${RED}ERROR: VPN config file not found at: $VPN_OVPN_PATH${NC}"
        echo "Please check the VPN_OVPN_PATH in your .env file."
        VALIDATION_FAILED=true
    else
        echo -e "${GREEN}✓${NC} VPN config file found: $VPN_OVPN_PATH"
    fi
    
    # Create VPN authentication file
    echo ""
    echo -e "${BLUE}Creating VPN authentication file...${NC}"
    cat > vpn-auth.txt << EOF
${VPN_USERNAME}
${VPN_PASSWORD}
EOF
    chmod 600 vpn-auth.txt
    
    if [ -f vpn-auth.txt ]; then
        echo -e "${GREEN}✓${NC} VPN authentication file created successfully."
    else
        echo -e "${RED}ERROR: Failed to create VPN authentication file.${NC}"
        VALIDATION_FAILED=true
    fi
    
    # Check OpenVPN configuration
    echo ""
    echo -e "${BLUE}Checking OpenVPN configuration...${NC}"
    
    if ! grep -q "auth-user-pass" "$VPN_OVPN_PATH" 2>/dev/null; then
        echo -e "${YELLOW}WARNING: OpenVPN config file doesn't contain 'auth-user-pass' directive.${NC}"
        read -p "Add 'auth-user-pass /vpn/vpn.auth' to your config file? (y/n): " -n 1 -r
        echo
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            cp "$VPN_OVPN_PATH" "${VPN_OVPN_PATH}.backup"
            echo "auth-user-pass /vpn/vpn.auth" >> "$VPN_OVPN_PATH"
            echo -e "${GREEN}✓ Added auth-user-pass directive to OpenVPN config.${NC}"
            echo -e "${BLUE}Backup created: ${VPN_OVPN_PATH}.backup${NC}"
        else
            echo -e "${YELLOW}Please manually add 'auth-user-pass /vpn/vpn.auth' to your OpenVPN config file.${NC}"
        fi
    else
        echo -e "${GREEN}✓${NC} OpenVPN config already contains auth-user-pass directive."
    fi
    
else
    echo ""
    echo -e "${YELLOW}VPN disabled - skipping VPN-specific validation.${NC}"
fi

# Check for validation failures
if [ "$VALIDATION_FAILED" = true ]; then
    echo ""
    echo -e "${RED}Please fix the missing variables in your .env file and try again.${NC}"
    exit 1
fi

# =============================================================================
# Directory Setup
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}          Directory Setup${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

# Download directory
if [ ! -d "$DOWNLOAD_DIR" ]; then
    echo -e "${YELLOW}Download directory does not exist: $DOWNLOAD_DIR${NC}"
    read -p "Create it? (y/n): " -n 1 -r
    echo
    
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        mkdir -p "$DOWNLOAD_DIR"
        echo -e "${GREEN}✓ Created download directory: $DOWNLOAD_DIR${NC}"
    else
        echo -e "${RED}Please create the download directory or update DOWNLOAD_DIR in .env${NC}"
        exit 1
    fi
else
    echo -e "${GREEN}✓${NC} Download directory exists: $DOWNLOAD_DIR"
fi

# CONST-034 anti-bluff: refuse to start if DOWNLOAD_DIR is on a
# tmpfs filesystem. With podman + systemd PrivateTmp, bind-mounts
# of tmpfs paths into containers fail SILENTLY — files appear in
# /proc but writes don't land on the host. The user's downloads
# would all show "finished" status while the disk stays empty.
# Loud refusal is better than a confusing later FAIL.
DOWNLOAD_DIR_FSTYPE=$(df -T "$DOWNLOAD_DIR" 2>/dev/null | awk 'NR==2 {print $2}')
if [ "$DOWNLOAD_DIR_FSTYPE" = "tmpfs" ]; then
    echo -e "${RED}✗ DOWNLOAD_DIR ($DOWNLOAD_DIR) is on a tmpfs filesystem.${NC}"
    echo -e "${RED}  Bind-mounting tmpfs paths into containers fails silently with podman${NC}"
    echo -e "${RED}  + systemd PrivateTmp on this host. Downloads will report 'finished'${NC}"
    echo -e "${RED}  but no file will appear on disk.${NC}"
    echo
    echo -e "${YELLOW}Fix: move DOWNLOAD_DIR off /tmp. Examples that work:${NC}"
    echo -e "${YELLOW}  - DOWNLOAD_DIR=\$HOME/Downloads/MeTube${NC}"
    echo -e "${YELLOW}  - DOWNLOAD_DIR=$(pwd)/downloads${NC}"
    echo -e "${YELLOW}  - DOWNLOAD_DIR=/var/lib/metube-downloads${NC}"
    exit 1
fi
echo -e "${GREEN}✓${NC} Download directory is on $DOWNLOAD_DIR_FSTYPE (not tmpfs)"

# Create yt-dlp directories
echo ""
echo -e "${BLUE}Creating yt-dlp directories...${NC}"
mkdir -p ./yt-dlp/config
mkdir -p ./yt-dlp/cookies
mkdir -p ./yt-dlp/archive
echo -e "${GREEN}✓${NC} Created yt-dlp directories"

# Create Metube directories
echo ""
echo -e "${BLUE}Creating Metube directories...${NC}"
mkdir -p ./metube/config
echo -e "${GREEN}✓${NC} Created Metube directories"

# =============================================================================
# Configuration Files
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Configuration Files${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

# Create default yt-dlp config if not exists
if [ ! -f ./yt-dlp/config/yt-dlp.conf ]; then
    echo -e "${BLUE}Creating default yt-dlp configuration...${NC}"
    cat > ./yt-dlp/config/yt-dlp.conf << 'EOF'
# =============================================================================
# YT-DLP Configuration File
# =============================================================================

# -----------------------------------------------------------------------------
# Output Settings
# -----------------------------------------------------------------------------
# Output template: Channel/Title - ID.ext
-o "/downloads/%(uploader)s/%(title)s - %(id)s.%(ext)s"

# Archive file to track downloaded videos
--download-archive /archive/downloaded.txt

# -----------------------------------------------------------------------------
# Format and Quality
# -----------------------------------------------------------------------------
# Format selection: Best video up to 1080p + best audio
-f "bestvideo[height<=?1080]+bestaudio/best"

# -----------------------------------------------------------------------------
# Subtitles
# -----------------------------------------------------------------------------
--write-sub
--sub-langs en,es,fr
--convert-subs srt

# -----------------------------------------------------------------------------
# Metadata
# -----------------------------------------------------------------------------
--add-metadata
--embed-thumbnail
--embed-subs

# -----------------------------------------------------------------------------
# Network Options
# -----------------------------------------------------------------------------
--retries 10
--fragment-retries 10

# -----------------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------------
--concurrent-fragments 5

# -----------------------------------------------------------------------------
# User Agent
# -----------------------------------------------------------------------------
--user-agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
--verbose
EOF
    echo -e "${GREEN}✓ Created default yt-dlp configuration${NC}"
else
    echo -e "${GREEN}✓${NC} yt-dlp configuration already exists"
fi

# =============================================================================
# Permissions
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}         Setting Permissions${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

chmod -R 755 ./yt-dlp ./metube 2>/dev/null || true
chmod 600 ./vpn-auth.txt 2>/dev/null || true
echo -e "${GREEN}✓${NC} Directory permissions set"

# =============================================================================
# Summary
# =============================================================================

echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}    Setup completed successfully! ✓${NC}"
echo -e "${GREEN}============================================${NC}"
echo ""

if [ "$USE_VPN" = "true" ]; then
    echo -e "${CYAN}Configuration:${NC} yt-dlp WITH VPN"
    echo ""
    echo "Files created/verified:"
    echo "  • vpn-auth.txt (VPN credentials)"
    echo "  • OpenVPN config: $VPN_OVPN_PATH"
    echo "  • Download directory: $DOWNLOAD_DIR"
    echo "  • yt-dlp config: ./yt-dlp/config/yt-dlp.conf"
    echo "  • Metube config: ./metube/config/"
    echo ""
    echo -e "${BLUE}Start with VPN:${NC}"
    echo "  $COMPOSE_CMD --profile vpn up -d"
    echo ""
    echo -e "${CYAN}Access URLs:${NC}"
    echo "  • Landing Page (VPN): http://localhost:8087"
    echo "  • MeTube (VPN):       http://localhost:8086"
    echo "  • Command Line: $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp 'VIDEO_URL'"
    echo "  • Check VPN IP: $CONTAINER_RUNTIME exec openvpn-yt-dlp wget -qO- ifconfig.me"
else
    echo -e "${CYAN}Configuration:${NC} yt-dlp WITHOUT VPN"
    echo ""
    echo "Files created/verified:"
    echo "  • Download directory: $DOWNLOAD_DIR"
    echo "  • yt-dlp config: ./yt-dlp/config/yt-dlp.conf"
    echo "  • Metube config: ./metube/config/"
    echo ""
    echo -e "${BLUE}Start without VPN:${NC}"
    echo "  $COMPOSE_CMD --profile no-vpn up -d"
    echo ""
    echo -e "${CYAN}Access URLs:${NC}"
    echo "  • Landing Page: http://localhost:8086 (Cookie Auth)"
    echo "  • MeTube:       http://localhost:8088 (Direct)"
    echo "  • Command Line: $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp 'VIDEO_URL'"
    echo ""
    echo -e "${YELLOW}WARNING: Running without VPN - your downloads are not protected!${NC}"
fi

echo ""
echo -e "${GREEN}Next steps:${NC}"
echo "  1. Start services: ./start"
echo "  2. Check status:   ./status"
echo "  3. Download video: ./download 'VIDEO_URL'"
