#!/bin/bash
#
# Restart YT-DLP services
# Supports both Podman and Docker
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}         Restarting Services${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/stop"
echo ""
"$SCRIPT_DIR/start"

echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}      Restart completed!${NC}"
echo -e "${GREEN}============================================${NC}"
