#!/bin/bash
#
# Start YT-DLP services WITHOUT VPN
# Supports both Podman and Docker (prefers Podman)
#

set -e

# Colors
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

get_compose_cmd() {
    local runtime="$1"
    if [ "$runtime" = "podman" ]; then
        if command -v podman-compose &> /dev/null; then
            echo "podman-compose"
        else
            echo "podman compose"
        fi
    else
        if command -v docker-compose &> /dev/null; then
            echo "docker-compose"
        else
            echo "docker compose"
        fi
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    echo "Please install Podman or Docker."
    exit 1
fi

COMPOSE_CMD=$(get_compose_cmd "$CONTAINER_RUNTIME")

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Initialize and Start
# =============================================================================

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Initializing Environment${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/init"

# =============================================================================
# Update Images
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Updating Container Images${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/update-images"

echo ""
echo -e "${YELLOW}Starting services WITHOUT VPN...${NC}"
echo -e "Runtime: ${CONTAINER_RUNTIME}"
echo ""

$COMPOSE_CMD --profile no-vpn up -d

echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}    Services started successfully!${NC}"
echo -e "${GREEN}============================================${NC}"
echo ""

echo -e "${YELLOW}WARNING: Running without VPN - your downloads are not protected!${NC}"
echo ""

echo -e "${BLUE}Quick Commands:${NC}"
echo ""
echo "Download single video:"
echo "  $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp 'https://www.youtube.com/watch?v=VIDEO_ID'"
echo ""
echo "Download from batch file:"
echo "  $CONTAINER_RUNTIME exec yt-dlp-cli yt-dlp --batch-file /config/urls.txt"
echo ""
echo "Check container logs:"
echo "  $COMPOSE_CMD logs -f"
echo ""
echo -e "${BLUE}View web interface:${NC}"
echo "  http://localhost:${METUBE_PORT:-8086}"
