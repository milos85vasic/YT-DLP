#!/bin/bash
#
# Start YT-DLP services WITHOUT VPN
# Supports both Podman and Docker (prefers Podman)
#

set -e

# Colors
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

get_compose_cmd() {
    local runtime="$1"
    if [ "$runtime" = "podman" ]; then
        if command -v podman-compose &> /dev/null; then
            echo "podman-compose"
        else
            echo "podman compose"
        fi
    else
        if command -v docker-compose &> /dev/null; then
            echo "docker-compose"
        else
            echo "docker compose"
        fi
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    echo "Please install Podman or Docker."
    exit 1
fi

COMPOSE_CMD=$(get_compose_cmd "$CONTAINER_RUNTIME")

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Initialize and Start
# =============================================================================

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Initializing Environment${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/init"

# =============================================================================
# Update Images
# =============================================================================

echo ""
echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}       Updating Container Images${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

"$SCRIPT_DIR/update-images"

echo ""
echo -e "${YELLOW}Starting services WITHOUT VPN...${NC}"
echo -e "Runtime: ${CONTAINER_RUNTIME}"
echo ""

# `|| true`: on arm64 the amd64-only yt-dlp-cli (PoT image) fails to create, so
# `up -d` returns non-zero even when the real no-vpn services start fine. Don't
# let that abort the script (set -e) — the readiness gate below is the real
# authority on whether the services we need are running.
if [ "$CONTAINER_RUNTIME" = "docker" ]; then
    $COMPOSE_CMD --profile no-vpn --profile docker up -d || true
else
    $COMPOSE_CMD --profile no-vpn up -d || true
fi

echo ""
echo -e "${BLUE}Verifying containers reached running state...${NC}"
# CONST-034: `up -d` returning 0 only means containers were SCHEDULED. Poll until
# the expected no-vpn services are actually running before claiming success.
_arch="$(uname -m)"
_expected="metube-direct metube-landing yt-dlp-dashboard"
# yt-dlp-cli uses the amd64-only PoT image — legitimately absent on arm64.
case "$_arch" in arm64|aarch64) : ;; *) _expected="$_expected yt-dlp-cli" ;; esac
_elapsed=0; _ready=false
while [ "$_elapsed" -lt 120 ]; do
    _ready=true
    for _c in $_expected; do
        $CONTAINER_RUNTIME ps --format '{{.Names}}' 2>/dev/null | grep -q "^${_c}$" || { _ready=false; break; }
    done
    [ "$_ready" = true ] && break
    sleep 2; _elapsed=$((_elapsed + 2))
done
echo ""
if [ "$_ready" = true ]; then
    echo -e "${GREEN}============================================${NC}"
    echo -e "${GREEN}    Services started successfully!${NC}"
    echo -e "${GREEN}============================================${NC}"
else
    echo -e "${YELLOW}============================================${NC}"
    echo -e "${YELLOW}    FAILED: containers did not reach running state within 120s${NC}"
    echo -e "${YELLOW}============================================${NC}"
    $CONTAINER_RUNTIME ps --format 'table {{.Names}}\t{{.Status}}' 2>/dev/null || true
    exit 1
fi
echo ""

echo -e "${YELLOW}WARNING: Running without VPN - your downloads are not protected!${NC}"
echo ""

echo -e "${BLUE}Access URLs (No VPN):${NC}"
echo ""
echo "  Landing Page:     http://localhost:8086"
echo "  MeTube Direct:    http://localhost:8088"
echo "  MeTube API:       http://localhost:8088/api/json/v1/"
echo ""
echo -e "${BLUE}Quick Commands:${NC}"
echo ""
echo "Download single video:"
echo "  podman exec yt-dlp-cli yt-dlp 'https://www.youtube.com/watch?v=VIDEO_ID'"
echo ""
echo "Download from batch file:"
echo "  podman exec yt-dlp-cli yt-dlp --batch-file /config/urls.txt"
echo ""
echo "Check container logs:"
echo "  podman-compose logs -f"
