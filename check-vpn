#!/bin/bash
#
# Check VPN connection status for YT-DLP
# Supports both Podman and Docker
#

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    exit 1
fi

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Check VPN Status
# =============================================================================

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}         VPN Connection Check${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

if [ "$USE_VPN" != "true" ]; then
    echo -e "${YELLOW}VPN is not enabled in configuration.${NC}"
    echo "Set USE_VPN=true in .env to enable VPN."
    exit 0
fi

echo -e "${CYAN}Container Runtime:${NC} $CONTAINER_RUNTIME"
echo ""

echo -e "${BLUE}Checking yt-dlp VPN connection...${NC}"
echo ""

# Check container status
if ! $CONTAINER_RUNTIME ps | grep -q openvpn-yt-dlp; then
    echo -e "${RED}ERROR: yt-dlp OpenVPN container is not running!${NC}"
    exit 1
fi

# Get IP information
IP_INFO=$($CONTAINER_RUNTIME exec openvpn-yt-dlp wget -qO- http://ipinfo.io/json 2>/dev/null) || true

if [ -z "$IP_INFO" ]; then
    echo -e "${RED}ERROR: Cannot retrieve IP information. VPN might not be connected.${NC}"
    exit 1
fi

# Parse JSON manually (basic parsing)
IP=$(echo "$IP_INFO" | grep -o '"ip":"[^"]*"' | cut -d'"' -f4)
COUNTRY=$(echo "$IP_INFO" | grep -o '"country":"[^"]*"' | cut -d'"' -f4)
CITY=$(echo "$IP_INFO" | grep -o '"city":"[^"]*"' | cut -d'"' -f4)
ORG=$(echo "$IP_INFO" | grep -o '"org":"[^"]*"' | cut -d'"' -f4)

echo -e "${CYAN}yt-dlp VPN Connection Status:${NC}"
echo "  • IP Address: $IP"
echo "  • Location: $CITY, $COUNTRY"
echo "  • Provider: $ORG"
echo ""

# Check if it looks like VPN
if echo "$ORG" | grep -qiE "vpn|proxy|hosting|datacenter|cloud"; then
    echo -e "${GREEN}✓ VPN connection appears to be active${NC}"
else
    echo -e "${YELLOW}⚠ WARNING: This might not be a VPN connection!${NC}"
fi

# Compare with JDownloader VPN if it's running
if $CONTAINER_RUNTIME ps | grep -q "^openvpn$"; then
    echo ""
    echo -e "${BLUE}Checking JDownloader VPN for comparison...${NC}"
    JD_IP=$($CONTAINER_RUNTIME exec openvpn wget -qO- http://ipinfo.io/ip 2>/dev/null || echo "Unable to get IP")
    if [ -n "$JD_IP" ] && [ "$JD_IP" != "$IP" ]; then
        echo "  • JDownloader VPN IP: $JD_IP"
        echo -e "${GREEN}✓ Using different VPN endpoints (good for load distribution)${NC}"
    elif [ "$JD_IP" = "$IP" ]; then
        echo "  • JDownloader VPN IP: $JD_IP"
        echo -e "${YELLOW}⚠ Both services using same VPN endpoint${NC}"
    fi
fi
