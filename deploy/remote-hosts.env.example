# Containers-submodule remote-distribution config (§11.4.76, §11.4.31).
# Registers the operator-provided remote host nezha.local for distributed
# booting of the ytdlp System. Consumed by containers/cmd/boot (--env) and
# containers/cmd/distributed-test. Project-level (NOT inside the submodule,
# §11.4.28 decoupling). No secrets here — SSH is key-based.
CONTAINERS_REMOTE_ENABLED=true
CONTAINERS_REMOTE_SCHEDULER=resource_aware

# Host 1: nezha — i7 7th-gen (8 threads), 62 GiB RAM, NVMe, Podman 5.7.1
CONTAINERS_REMOTE_HOST_1_NAME=nezha
CONTAINERS_REMOTE_HOST_1_ADDRESS=nezha.local
CONTAINERS_REMOTE_HOST_1_USER=milosvasic
CONTAINERS_REMOTE_HOST_1_PORT=22
CONTAINERS_REMOTE_HOST_1_RUNTIME=podman
CONTAINERS_REMOTE_HOST_1_LABELS=gpu=false,arch=amd64,role=heavy-testing
