#!/bin/bash
#
# Status checker for YT-DLP services
# Supports both Podman and Docker
#

# §11.4.67 (target-shell-parseability): this script uses bash-4 associative arrays
# (declare -A, below); macOS /bin/bash is 3.2 and lacks them. Re-exec under a
# bash >= 4 if the current shell is too old, so the script runs on macOS too.
if [ -z "${BASH_VERSINFO:-}" ] || [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
    for _nb in /opt/homebrew/bin/bash /usr/local/bin/bash "$(command -v bash 2>/dev/null)"; do
        [ -n "${_nb:-}" ] && [ -x "$_nb" ] || continue
        _v="$("$_nb" -c 'echo "${BASH_VERSINFO[0]:-0}"' 2>/dev/null)"
        case "$_v" in ''|*[!0-9]*) continue;; esac
        [ "$_v" -ge 4 ] && exec "$_nb" "$0" "$@"
    done
    echo "ERROR: $0 requires bash >= 4 (current: ${BASH_VERSION:-unknown}); install a newer bash (e.g. 'brew install bash')." >&2
    exit 1
fi

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    exit 1
fi

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Main Status Display
# =============================================================================

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}         Service Status${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""

echo -e "${CYAN}Container Runtime:${NC} $CONTAINER_RUNTIME"

if [ -f .env ]; then
    echo -e "${CYAN}VPN Enabled:${NC} ${USE_VPN:-false}"
fi
echo ""

# Check all containers
echo -e "${BLUE}Services:${NC}"
declare -A containers=(
    ["openvpn"]="JDownloader VPN"
    ["jdownloader2"]="JDownloader"
    ["openvpn-yt-dlp"]="yt-dlp VPN"
    ["yt-dlp-cli"]="yt-dlp CLI"
    ["metube"]="Metube (with VPN)"
    ["metube-direct"]="Metube (no VPN)"
    ["yt-dlp-dashboard"]="YT-DLP Dashboard"
    ["watchtower"]="Watchtower (Docker only)"
)

for container in "${!containers[@]}"; do
    if $CONTAINER_RUNTIME ps --format "table {{.Names}}" | grep -q "^${container}$"; then
        STATUS=$($CONTAINER_RUNTIME inspect -f '{{.State.Status}}' $container 2>/dev/null || echo "unknown")
        echo -e "  ${GREEN}✓${NC} ${containers[$container]}: ${GREEN}$STATUS${NC}"
        
        # Additional info for VPN containers
        if [[ "$container" =~ ^openvpn ]]; then
            if [ "$STATUS" = "running" ]; then
                IP=$($CONTAINER_RUNTIME exec $container wget -qO- ifconfig.me 2>/dev/null || echo "Unable to get IP")
                echo "      External IP: $IP"
            fi
        fi
    else
        # Check if container exists but is stopped
        if $CONTAINER_RUNTIME ps -a --format "table {{.Names}}" | grep -q "^${container}$"; then
            echo -e "  ${YELLOW}○${NC} ${containers[$container]}: stopped"
        else
            echo -e "  ${RED}✗${NC} ${containers[$container]}: not found"
        fi
    fi
done

# HTTP Health Checks
# CONST-034 (§7.1 "body, not status"): a 200 alone is not health — an HTML 502
# wrapped in 200, or a curl 000 early-close, must read as UNHEALTHY. Require the
# expected body token to be present in the response, per endpoint.
health_check() {
    local url="$1" name="$2" expect="$3"
    local body
    body=$(curl -s --max-time 8 "$url" 2>/dev/null || echo "")
    if [ -n "$body" ] && echo "$body" | grep -qF "$expect"; then
        echo -e "  ${GREEN}✓${NC} $name responds (body matched '$expect')"
    else
        echo -e "  ${RED}✗${NC} $name UNHEALTHY (missing '$expect' in body)"
    fi
}

echo ""
echo -e "${BLUE}HTTP Health Checks:${NC}"
health_check "http://localhost:8088/history"          "MeTube Direct API"  '"queue"'
health_check "http://localhost:9090/api/history"       "Dashboard Proxy API" '"queue"'
health_check "http://localhost:8086/api/cookie-status" "Landing Page API"   '"has_cookies"'
health_check "http://localhost:9090/"                  "Dashboard HTML"     'chunk-'
health_check "http://localhost:8086/"                  "Landing Page HTML"  'Боба'

# Port status
echo ""
echo -e "${BLUE}Exposed Ports:${NC}"
ss -tuln 2>/dev/null | grep -E ':(3129|3130|5800|5900|8080|8081|8086|8087|8088|9090)' | while read line; do
    PORT=$(echo $line | grep -oE ':[0-9]+' | sed 's/://')
    case $PORT in
        3129)
            echo "  • Port $PORT: JDownloader VPN"
            ;;
        3130)
            echo "  • Port $PORT: yt-dlp VPN"
            ;;
        5800)
            echo "  • Port $PORT: JDownloader Web UI"
            ;;
        5900)
            echo "  • Port $PORT: JDownloader VNC"
            ;;
        8080|8081)
            echo "  • Port $PORT: yt-dlp API (internal)"
            ;;
        8086)
            echo "  • Port $PORT: Landing Page (No VPN)"
            ;;
        8087)
            echo "  • Port $PORT: Landing Page (VPN)"
            ;;
        8088)
            echo "  • Port $PORT: Metube Direct (No VPN)"
            ;;
        9090)
            echo "  • Port $PORT: YT-DLP Dashboard"
            ;;
    esac
done || echo "  (Unable to check ports - install 'iproute2' or 'net-tools')"

# Disk usage
echo ""
echo -e "${BLUE}Disk Usage:${NC}"
if [ -d "${DOWNLOAD_DIR}" ]; then
    SIZE=$(du -sh "${DOWNLOAD_DIR}" 2>/dev/null | cut -f1)
    echo "  • Downloads: $SIZE (${DOWNLOAD_DIR})"
fi

# Container runtime storage
echo ""
echo -e "${BLUE}Container Storage:${NC}"
if [ "$CONTAINER_RUNTIME" = "podman" ]; then
    podman system df 2>/dev/null | head -10 || echo "  Unable to get storage info"
else
    docker system df 2>/dev/null | head -10 || echo "  Unable to get storage info"
fi
