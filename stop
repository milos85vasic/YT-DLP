#!/bin/bash
#
# Stop YT-DLP services
# Works with both Podman and Docker
#

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

get_compose_cmd() {
    local runtime="$1"
    if [ "$runtime" = "podman" ]; then
        if command -v podman-compose &> /dev/null; then
            echo "podman-compose"
        else
            echo "podman compose"
        fi
    else
        if command -v docker-compose &> /dev/null; then
            echo "docker-compose"
        else
            echo "docker compose"
        fi
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${YELLOW}WARNING: No container runtime found!${NC}"
    echo "Cannot stop services."
    exit 1
fi

COMPOSE_CMD=$(get_compose_cmd "$CONTAINER_RUNTIME")

# =============================================================================
# Load Environment
# =============================================================================

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# =============================================================================
# Stop Services
# =============================================================================

echo -e "${BLUE}Stopping all services...${NC}"
echo -e "Runtime: ${CONTAINER_RUNTIME}"
echo ""

# podman-compose/docker compose only act on services in the profiles passed.
# Services here declare profiles (no-vpn/vpn/vpn-cli/docker), so `down` with NO
# profile resolves to an empty service set and silently stops nothing. Pass all
# profiles so `down` targets every service regardless of how it was started.
$COMPOSE_CMD --profile no-vpn --profile vpn --profile vpn-cli --profile docker down 2>/dev/null || true

# Clean up any remaining resources
if [ "$CONTAINER_RUNTIME" = "podman" ]; then
    podman pod ls --format "{{.Name}}" | grep -E "^pod_(yt-dlp|ytdlp)$" | xargs -r podman pod rm -f 2>/dev/null || true
    podman network rm yt-dlp_default ytdlp_default 2>/dev/null || true
fi

# Belt-and-suspenders: force-remove any of OUR named services that survived the
# compose down (e.g. started under a different compose project name). The list
# is this project's exact container names — neighbour containers are untouched.
for _c in metube-direct metube-landing yt-dlp-dashboard metube yt-dlp-cli openvpn-yt-dlp landing-vpn; do
    $CONTAINER_RUNTIME rm -f "$_c" 2>/dev/null || true
done

# CONST-034: verify the real end-state — do not just claim success.
_remaining=$($CONTAINER_RUNTIME ps --format '{{.Names}}' 2>/dev/null \
    | grep -E '^(metube-direct|metube-landing|yt-dlp-dashboard|metube|yt-dlp-cli|openvpn-yt-dlp|landing-vpn)$' || true)
echo ""
if [ -z "$_remaining" ]; then
    echo -e "${GREEN}All services stopped.${NC}"
else
    echo -e "${YELLOW}WARNING: these YT-DLP containers are STILL running:${NC}"
    echo "$_remaining"
    exit 1
fi