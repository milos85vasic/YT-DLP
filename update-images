#!/bin/bash
#
# Update container images to latest versions
# Supports both Podman and Docker
# Run this before starting containers to ensure latest images
#

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =============================================================================
# Container Runtime Detection
# =============================================================================

detect_container_runtime() {
    if command -v podman &> /dev/null; then
        echo "podman"
    elif command -v docker &> /dev/null; then
        echo "docker"
    else
        echo "none"
    fi
}

CONTAINER_RUNTIME=$(detect_container_runtime)

if [ "$CONTAINER_RUNTIME" = "none" ]; then
    echo -e "${RED}ERROR: No container runtime found!${NC}"
    exit 1
fi

# =============================================================================
# Images to Update
# =============================================================================

IMAGES=(
    "ghcr.io/alexta69/metube:latest"
    "ghcr.io/jim60105/yt-dlp:pot"
    "dperson/openvpn-client:latest"
)

if [ "$CONTAINER_RUNTIME" = "docker" ]; then
    IMAGES+=("containrrr/watchtower:latest")
fi

# =============================================================================
# Update Images
# =============================================================================

echo -e "${BLUE}============================================${NC}"
echo -e "${BLUE}      Updating Container Images${NC}"
echo -e "${BLUE}============================================${NC}"
echo ""
echo -e "${CYAN}Container Runtime:${NC} $CONTAINER_RUNTIME"
echo ""

unusable=0
for image in "${IMAGES[@]}"; do
    echo -e "${BLUE}Pulling:${NC} $image"
    if $CONTAINER_RUNTIME pull "$image" >/dev/null 2>&1; then
        echo -e "${GREEN}✓${NC} Updated: $image"
    else
        # A pull can legitimately fail while a usable image is already cached
        # (offline) OR the image has no build for this arch (e.g. the amd64-only
        # PoT image on arm64). "may be cached" is only true if it ACTUALLY is —
        # CONST-034: prove it rather than assume.
        if $CONTAINER_RUNTIME image inspect "$image" >/dev/null 2>&1; then
            echo -e "${YELLOW}⚠${NC} Failed to update: $image (using cached local image)"
        else
            echo -e "${YELLOW}⚠${NC} Failed to update: $image (no local cache available)"
            unusable=$((unusable + 1))
        fi
    fi
done

# CONST-034: don't print "completed" as success if NO image is pullable or
# cached — that would be a false success masking a broken environment.
if [ "$unusable" -eq "${#IMAGES[@]}" ]; then
    echo ""
    echo -e "${YELLOW}ERROR: none of the ${#IMAGES[@]} images could be pulled or found locally.${NC}"
    exit 1
fi

echo ""
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}   Image update check completed!${NC}"
echo -e "${GREEN}============================================${NC}"
